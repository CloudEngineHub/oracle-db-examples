        "forms" : "[]",
        "result" : {
          "startTime" : 1783044516059,
          "endTime" : 1783044518683,
          "interpreter" : "script.medium",
          "taskStatus" : "SUCCESS",
          "status" : "SUCCESS",
          "results" : [
            {
              "message" : "Dropped table: CLIENTS\nDropped table: CONTACTS\nDropped table: PAST_CAMPAIGNS\nDropped table: PROSPECTS\n\n\nPL/SQL procedure successfully completed.\n\n",
              "type" : "TEXT"
            }
          ],
          "forms" : "[]"
        },
