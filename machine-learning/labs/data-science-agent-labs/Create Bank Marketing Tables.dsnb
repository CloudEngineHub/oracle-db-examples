        "dynamicFormParams" : "{}"
      },
      {
        "row" : 0,
        "col" : 0,
        "sizeX" : 0,
        "width" : 0,
        "title" : "Create tables",
        "hasTitle" : true,
        "message" : [
          "%script",
          "",
          "CREATE TABLE CLIENTS (",
          "    client_id NUMBER(10) PRIMARY KEY,",
          "    age NUMBER(3),",
          "    job VARCHAR2(30),",
          "    marital VARCHAR2(10),",
          "    education VARCHAR2(20),",
          "    default_credit VARCHAR2(5),",
          "    balance NUMBER,",
          "    housing_loan VARCHAR2(5),",
          "    personal_loan VARCHAR2(5)",
          ");",
          "",
          "CREATE TABLE CONTACTS (",
          "    client_id NUMBER(10),",
          "    contact_type VARCHAR2(15),",
          "    contact_date DATE,",
          "    duration_seconds NUMBER,",
          "    contacts_during_campaign NUMBER,",
          "    subscribed CHAR(1),",
          "    FOREIGN KEY (client_id) REFERENCES CLIENTS(client_id)",
          ");",
          "",
          "CREATE TABLE PAST_CAMPAIGNS (",
          "    client_id NUMBER(10),",
          "    days_from_last_contact NUMBER,",
          "    previous_contacts NUMBER,",
          "    past_outcomes VARCHAR2(15),",
          "    FOREIGN KEY (client_id) REFERENCES CLIENTS(client_id)",
          ");",
          "",
          "CREATE TABLE PROSPECTS (",
          "    client_id NUMBER(10) PRIMARY KEY,",
          "    FOREIGN KEY (client_id) REFERENCES CLIENTS(client_id)",
          ");"
        ],
        "selectedVisualization" : "raw",
        "visualizationConfig" : null,
        "hideCode" : false,
        "hideResult" : false,
