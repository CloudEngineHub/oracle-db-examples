        "width" : 0,
        "title" : "Copy data to tables",
        "hasTitle" : true,
        "message" : [
          "%script",
          "",
          "BEGIN",
          "   DBMS_CLOUD.COPY_DATA(",
          "      table_name => 'CLIENTS',",
          "      --credential_name => 'OCI_CRED',",
          "      file_uri_list => 'https://adwc4pm.objectstorage.us-ashburn-1.oci.customer-oci.com/p/wbELPVyAywtLhceEOFwFmcM85DRJ8qBvOzwoWAZjyTTSL9ggaSBk--LLSb14dxEj/n/adwc4pm/b/OML-Resources/o/clients.csv',",
          "      format => '{\"type\":\"csv\",\"skipheaders\":\"1\"}'",
          "   );",
          "END;",
          "/",
          "",
          "BEGIN",
          "   DBMS_CLOUD.COPY_DATA(",
          "      table_name => 'CONTACTS',",
          "      --credential_name => 'OCI_CRED',",
          "      file_uri_list => 'https://adwc4pm.objectstorage.us-ashburn-1.oci.customer-oci.com/p/Q84j7A9M7qiecz0w7xj2eWGG5v44xfRrCy7iOzKb5M_sr7kIyfALastLIk0Brtar/n/adwc4pm/b/OML-Resources/o/current_campaign_contacts.csv',",
          "      format => '{\"type\":\"csv\",\"skipheaders\":\"1\",\"dateformat\":\"MM/DD/YYYY\"}'",
          "   );",
          "END;",
          "/",
          "",
          "BEGIN",
          "   DBMS_CLOUD.COPY_DATA(",
          "      table_name => 'PAST_CAMPAIGNS',",
          "      --credential_name => 'OCI_CRED',",
          "      file_uri_list => 'https://adwc4pm.objectstorage.us-ashburn-1.oci.customer-oci.com/p/SJp0mSRXiJVASZbtYN3UfI5TOlZXLWK2s10KOWjgBc6oJbfgQTlLAcYw-ZRiFDmW/n/adwc4pm/b/OML-Resources/o/past_campaigns.csv',",
          "      format => '{\"type\":\"csv\",\"skipheaders\":\"1\",\"blankasnull\":\"true\",\"rejectlimit\":\"unlimited\"}'",
          "   );",
          "END;",
          "/",
          "",
          "BEGIN",
          "   DBMS_CLOUD.COPY_DATA(",
          "      table_name => 'PROSPECTS',",
          "      --credential_name => 'CLOUD_CRED',",
          "      file_uri_list => 'https://adwc4pm.objectstorage.us-ashburn-1.oci.customer-oci.com/p/1LO9XJs7mPLk0oSlIOjpdgNO53rTvRzKArQcA0dGEnr2qe2Rz6_078pXyt1wamho/n/adwc4pm/b/OML-Resources/o/prospects.csv',",
          "      format => '{\"type\":\"csv\",\"skipheaders\":\"1\"}'",
          "   );",
          "END;",
          "/"
        ],
